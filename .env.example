# Copy to `.env` and adjust if your tooling loads env vars into Django.
# Django reads PUBLIC_BASE_URL via os.environ (export in shell or use a process manager).

# Public API root (no trailing slash) — current deployment:
PUBLIC_BASE_URL=http://16.16.160.64:8000

# Optional: GDAL/GEOS paths for django.contrib.gis (Ubuntu server)
# GDAL_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu/libgdal.so
# GEOS_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu/libgeos_c.so

# Celery broker (install redis-server on the host)
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
DB_CONN_MAX_AGE=0

# Run with Daphne (after `python3 -m venv .venv && .venv/bin/pip install -r requirements.txt`):
#   export PUBLIC_BASE_URL=http://16.16.160.64:8000
#   .venv/bin/daphne -b 0.0.0.0 -p 8000 core.asgi:application
